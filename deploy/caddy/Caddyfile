# Remote Agent TUI Manager
# Reverse proxy with auto-HTTPS
#
# Usage: caddy run --config Caddyfile
# Or with Tailscale HTTPS: uncomment auto_https off and use Tailscale cert

{
    # auto_https off  # uncomment if using Tailscale HTTPS instead
}

:443 {
    reverse_proxy localhost:3000
}

# HTTP redirect (optional)
:80 {
    redir https://{host}{uri} permanent
}