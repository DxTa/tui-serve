[Unit]
Description=Remote Agent TUI Manager
After=network.target tailscaled.service
Wants=tailscaled.service

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/remote-agent-tui/server
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5

# Environment — override these in /etc/systemd/system/remote-agent-tui.service.d/override.conf
Environment=NODE_ENV=production
Environment=AUTH_TOKEN=change-me-set-in-override
Environment=PORT=3000

StandardOutput=journal
StandardError=journal
SyslogIdentifier=remote-agent-tui

[Install]
WantedBy=multi-user.target